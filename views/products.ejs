<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <title>M&G</title>
    <style>
        .carousel-inner img {
            width: 100%;
            height: auto;
            object-fit: cover;
        }
    </style>
    <link rel="icon" type="image/x-icon" href="/assets/img/icon.jpg">
</head>

<body>

    <!-- nav -->

    <header>
        <nav class="navbar navbar-expand-lg bg-body-tertiary">
            <div class="container-fluid">
                <a class="navbar-brand" href="#">
                    <em>
                        <h2><i class="bi bi-egg-fried pe-2"></i>Meat & Greet</h2>
                    </em>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false"
                    aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-end" id="navbarNavDropdown">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link active" aria-current="page" href="/"><i class="bi bi-house"></i> Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/category"><i class="bi bi-menu-button-wide-fill"></i> Menu</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#"><i class="bi bi-file-person-fill me-2"></i>About</a>
                        </li>
                        <li class="nav-item"> <button type="button" class="btn btn-outline-secondary"><i
                                    class="bi bi-box-arrow-in-right me-2"></i><a href="/login">Login</a></button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- scroolspy -->

    <nav id="navbar-example2" class="navbar bg-body-tertiary px-3 mb-3">
        <a class="navbar-brand" href="#">Menu</a>
        <ul class="nav nav-pills">
            <li class="nav-item">
                <a class="nav-link" href="#scrollspyHeading1"></a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#scrollspyHeading2"></a>
            </li>
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button"
                    aria-expanded="false">Dropdown</a>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="#scrollspyHeading3"></a></li>
                    <li><a class="dropdown-item" href="#scrollspyHeading4"></a></li>
                    <li>
                        <hr class="dropdown-divider">
                    </li>
                    <li><a class="dropdown-item" href="#scrollspyHeading5"></a></li>
                </ul>
            </li>
        </ul>
    </nav>

    <main data-bs-spy="scroll" data-bs-target="#navbar-example2" data-bs-root-margin="0px 0px -40%"
        data-bs-smooth-scroll="true" class="scrollspy-example bg-body-tertiary p-3 rounded-2" tabindex="0">

        <div class="container" id="scrollspyHeading1">
            <% data.forEach(product=>{ %>
            <div class="row p-3 w-100" style="height: 400px;">
                <div class="col-8">
                    <div class="card mb-3 h-100" style="max-width: auto;">
                        <div class="row g-0">
                            <div class="col-md-4">
                                <img src="/assets/img/burger.jpg" class="img-fluid rounded-start" alt="...">
                            </div>
                            <div class="col-md-8">
                                <div class="card-body">
                                    <h5 class="card-title"><%= product.name %></h5>
                                    <p class="card-text">Description : <%= product.description %></p>
                                </div>
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item">Category : <%= product.category.name %></li>
                                    <li class="list-group-item">A second item</li>
                                    <li class="list-group-item">A third item</li>
                                </ul>
                                <div class="card-body">
                                    <button type="button" class="btn btn-outline-warning">Add to cart</button>
                                    <button type="button" class="btn btn-outline-info">View Details</button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="col-4">
                    <div class="card border-dark mb-3 h-100">
                        <div class="card-header"><h3>Rs. <%= product.rate %></h3></div>
                        <div class="card-body">
                            <h5 class="card-title">Rating : <%= product.rating %></h5>
                            <p class="card-text">Some quick example text to build on the card title and make up the bulk
                                of the card's content.</p>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
        </div>

        
        <!-- pokki adi -->

        <div class="container my-5">
            <div class="row">
                <div class="col-xs-12 col-sm-12 col-md-6 col-lg-3 col-xl-3 ">
                    <i class="bi bi-bag-check " style="font-size: 60px;"></i>
                    <h6>Free Delivery</h6>
                    <p>Please note that free delivery is only for orders above a specific amount.</p>
                </div>
                <div class="col-xs-12 col-sm-12 col-md-6 col-lg-3 col-xl-3 ">
                    <i class="bi bi-credit-card" style="font-size: 60px;"></i>
                    <h6>100% Secure Payment</h6>
                    <p>Please note that free delivery is only for orders above a specific amount.</p>
                </div>
                <div class="col-xs-12 col-sm-12 col-md-6 col-lg-3 col-xl-3 ">
                    <i class="bi bi-tag" style="font-size: 60px;"></i>
                    <h6>Daily Offer</h6>
                    <p>Please note that free delivery is only for orders above a specific amount.</p>
                </div>
                <div class="col-xs-12 col-sm-12 col-md-6 col-lg-3 col-xl-3 ">
                    <i class="bi bi-star-fill" style="font-size: 60px;"></i>
                    <h6>Quality Guarantee</h6>
                    <p>Please note that free delivery is only for orders above a specific amount.</p>
                </div>
            </div>
        </div>

    </main>

    <!-- footer -->

    <div class="container-fluid bg-light">
        <hr>
        <div class="container">
            <div class="row">
                <div class="col-md-3 d-12 d-md-block d-flex justify-content-center">
                    <h3 class="text-center pb-4"><i class="bi bi-egg-fried me-2"></i>M&G</h3>
                    <p class="text-center">Kerala's number 1 Meat</p>
                    <p class="text-center">Get in touch with our socials</p>
                    <p class="text-center">
                        <i class="bi bi-instagram m-2"></i>
                        <i class="bi bi-facebook m-2"></i>
                        <i class="bi bi-whatsapp m-2"></i>
                    </p>
                </div>

                <div class="col-md-3 d-none d-md-block">
                    <h4 class="d-flex justify-content-center">Quick Links</h4>
                    <p class="d-flex justify-content-center">Home</p>
                    <p class="d-flex justify-content-center">About Us</p>
                    <p class="d-flex justify-content-center">Offer</p>
                    <p class="d-flex justify-content-center">Services</p>
                    <p class="d-flex justify-content-center">Contact Us</p>
                </div>
                <div class="col-md-3 d-none d-md-block d-flex justify-content-center">
                    <h4 class="d-flex justify-content-center">Help Center</h4>
                    <p class="d-flex justify-content-center">FAQ's</p>
                    <p class="d-flex justify-content-center">Payment</p>
                    <p class="d-flex justify-content-center">Returns & Refunds</p>
                    <p class="d-flex justify-content-center">Checkout</p>
                    <p class="d-flex justify-content-center">Delivery Information</p>
                </div>
                <div class="col-md-3 d-none d-md-block d-flex justify-content-center">
                    <h3 class="d-flex justify-content-center">Our Newsletter</h3>
                    <p class="mt-4">Subscribe to out newsletter to get updates about our grand offers.</p>
                    <div class="input-group mt-4">
                        <input type="text" class="form-control" placeholder="username" aria-label="Recipient's username"
                            aria-describedby="basic-addon2">
                        <div class="input-group-append">
                            <span class="input-group-text" id="basic-addon2">Sub !</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid">
        <hr class="m-0">
    </div>

    <div class="container-fluid bg-light">
        <p class="text-center p-3 m-0">© 2023 Meat&Greet. All rights reserved.</p>
    </div>

    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
</body>

</html>