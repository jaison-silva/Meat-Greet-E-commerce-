        </div>
        <div class="col-md-3 d-none d-md-block d-flex justify-content-center">
          <h4 class="d-flex justify-content-center">Help Center</h4>
          <p class="d-flex justify-content-center">FAQ's</p>
          <p class="d-flex justify-content-center">Payment</p>
          <p class="d-flex justify-content-center">Returns & Refunds</p>
