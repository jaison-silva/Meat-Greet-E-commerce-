<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <title>M&G</title>
    <style>
        .carousel-inner img {
            width: 100%;
            height: auto;
            object-fit: cover;
        }
    </style>
    <link rel="icon" type="image/x-icon" href="/assets/img/icon.jpg">
</head>

<body>

    <!-- nav -->

    <header>
        <nav class="navbar navbar-expand-lg bg-body-tertiary">
            <div class="container-fluid">
                <a class="navbar-brand" href="#">
                    <em>
                        <h2><i class="bi bi-egg-fried pe-2"></i>Meat & Greet</h2>
                    </em>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false"
                    aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-end" id="navbarNavDropdown">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link active" aria-current="page" href="#"><i class="bi bi-house"></i> Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#"><i class="bi bi-menu-button-wide-fill"></i> Menu</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#"><i class="bi bi-file-person-fill me-2"></i>About</a>
                        </li>
                        <li class="nav-item"> <button type="button" class="btn btn-outline-secondary"><i
                                    class="bi bi-box-arrow-in-right me-2"></i>Login</button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- main -->

    <main class="container d-flex flex-wrap p-5 g-5">
        <div class="col-md-3 mb-3 border border-rounded border-left-0">
            <h3 class="text-center">Admin</h3>
            <ul class="nav nav-pills flex-column">
                <li class="nav-item">
                    <a class="nav-link " href="/admin">Overview</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link " href="/addcategory">Category</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" href="/addproducts">Products</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">Manage Users</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">Coupons</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">Settings</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/">Logout</a>
                </li>
            </ul>
        </div>
        <div class="col-md-9">
            <div class="container ">
                <div class="m-5 p-5 d-flex justify-content-center border border-secondary rounded">
                    <form class="row g-3" action="/api_addProducts" method="POST">
                        <h3 class="text-center">Add Products !</h3>
                        <div class="col-md-12">
                            <label for="inputEmail4" class="form-label">Name</label>
                            <input class="form-control" id="inputEmail4" required name="name">
                        </div>
                        <div class="form-group">
                            <label for="exampleFormControlTextarea1">Description</label>
                            <textarea class="form-control" id="exampleFormControlTextarea1" rows="3" required
                                name="description"></textarea>
                        </div>
                        <div class="col-md-12">
                            <label for="inputEmail4" class="form-label">Rating</label>
                            <input class="form-control" id="inputEmail4" required name="rating">
                        </div>
                        <div class="col-md-12">
                            <div class="col-12">
                                <label for="inputPassword" class="form-label">Rate</label>
                                <input type="text" class="form-control" id="inputPassword" placeholder="*******"
                                    required name="rate">
                            </div>
                            <div class="col-md-12">

                            </div>
                            <div class="form-check my-3 p-0">
                                <!-- Example split danger button -->
                                <label for="inputPassword" class="form-label">Category</label>
                                <select class="form-select" aria-label="Default select example" name="category">
                                    <% data.forEach(category=> { %>
                                        <option value="<%=category.id%>"><%=category.name%></option>
                                     <% }) %>
                                  </select>
                            </div>
                        </div>
                        <div>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary w-100">Add Products</button>
                        </div>
                    </form>
    </main>


    <!-- footer -->

    <div class="container-fluid bg-light">
        <hr>
        <div class="container">
            <div class="row">
                <div class="col-md-3 d-12 d-md-block d-flex justify-content-center">
                    <h3 class="text-center pb-4"><i class="bi bi-egg-fried me-2"></i>M&G</h3>
                    <p class="text-center">Kerala's number 1 Meat</p>
                    <p class="text-center">Get in touch with our socials</p>
                    <p class="text-center">
                        <i class="bi bi-instagram m-2"></i>
                        <i class="bi bi-facebook m-2"></i>
                        <i class="bi bi-whatsapp m-2"></i>
                    </p>
                </div>

                <div class="col-md-3 d-none d-md-block">
                    <h4 class="d-flex justify-content-center">Quick Links</h4>
                    <p class="d-flex justify-content-center">Home</p>
                    <p class="d-flex justify-content-center">About Us</p>
                    <p class="d-flex justify-content-center">Offer</p>
                    <p class="d-flex justify-content-center">Services</p>
                    <p class="d-flex justify-content-center">Contact Us</p>
                </div>
                <div class="col-md-3 d-none d-md-block d-flex justify-content-center">
                    <h4 class="d-flex justify-content-center">Help Center</h4>
                    <p class="d-flex justify-content-center">FAQ's</p>
                    <p class="d-flex justify-content-center">Payment</p>
                    <p class="d-flex justify-content-center">Returns & Refunds</p>
                    <p class="d-flex justify-content-center">Checkout</p>
                    <p class="d-flex justify-content-center">Delivery Information</p>
                </div>
                <div class="col-md-3 d-none d-md-block d-flex justify-content-center">
                    <h3 class="d-flex justify-content-center">Our Newsletter</h3>
                    <p class="mt-4">Subscribe to out newsletter to get updates about our grand offers.</p>
                    <div class="input-group mt-4">
                        <input type="text" class="form-control" placeholder="username" aria-label="Recipient's username"
                            aria-describedby="basic-addon2">
                        <div class="input-group-append">
                            <span class="input-group-text" id="basic-addon2">Sub !</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid">
        <hr class="m-0">
    </div>

    <div class="container-fluid bg-light">
        <p class="text-center p-3 m-0">© 2023 Meat&Greet. All rights reserved.</p>
    </div>

    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
</body>

</html>